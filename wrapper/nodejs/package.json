{
  "name": "timslite-node",
  "version": "0.1.0",
  "description": "Node.js native addon for the timslite time-series storage library.",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "napi build --platform --dts auto-generated.d.ts",
    "build:debug": "napi build --platform --mode=debug --dts auto-generated.d.ts",
    "test": "echo \"Tests not yet implemented\""
  },
  "napi": {
    "binaryName": "timslite-node",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/snower/timslite"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3"
  }
}
