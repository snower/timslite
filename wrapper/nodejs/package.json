{
  "name": "timslite",
  "version": "0.1.1",
  "description": "Node.js native addon for the timslite time-series storage library.",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "README.md",
    "index.js",
    "index.d.ts",
    "auto-generated.d.ts",
    "binding-target.js",
    "scripts/**",
    "Cargo.toml",
    "Cargo.lock",
    "build.rs",
    "src/**",
    "*.node"
  ],
  "scripts": {
    "build": "napi build --platform --no-js --dts auto-generated.d.ts",
    "build:debug": "napi build --platform --no-js --mode=debug --dts auto-generated.d.ts",
    "postinstall": "node scripts/install.js",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "napi": {
    "binaryName": "timslite",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snower/timslite.git"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3",
    "tsx": "^4.22.4"
  }
}
